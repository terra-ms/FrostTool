# Copy this file to .env and adjust values.

# ── Docker Compose ────────────────────────────────────────────────────────────
# Path to the local AgERA5 data directory (parent of tmean_v2/, tmin_v2/, precomputed/).
# Windows (Docker Desktop): use forward slashes
# Example: C:/Olivier/Terra local/data/AgERA5
AGERA5_DATA_PATH=C:/Olivier/Terra local/data/AgERA5

# ── S3 (Fargate / production) ─────────────────────────────────────────────────
# Set S3_BUCKET to enable S3 mode. Leave blank for local/docker-compose mode.
# In S3 mode, DATA_ROOT_* and PRECOMPUTED_DIR only need to contain the folder name
# (e.g. "tmean_v2"), not a real path — the app uses the name as the S3 key prefix.
S3_BUCKET=

# ── Backend ───────────────────────────────────────────────────────────────────
DATA_ROOT_MEAN=C:/Olivier/Terra local/data/AgERA5/tmean_v2
DATA_ROOT_MIN=C:/Olivier/Terra local/data/AgERA5/tmin_v2
PRECOMPUTED_DIR=C:/Olivier/Terra local/data/AgERA5/precomputed
CACHE_DIR=.cache
GDD_WARMUP_MIN_YEAR=2000
ALLOWED_ORIGINS=http://localhost:8050,http://127.0.0.1:8050
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# ── Frontend ──────────────────────────────────────────────────────────────────
# Internal URL used for server-side Python requests (use Docker service name in Compose)
REACT_APP_API_URL=http://localhost:8000/api/v1
# Public URL embedded in iframe JS and fetched by the browser
PUBLIC_API_URL=http://localhost:8000/api/v1
DASH_DEBUG=false
FRONTEND_HOST=0.0.0.0
FRONTEND_PORT=8050

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
